# Copy to .env on the VDS and replace every secret.
POSTGRES_DB=focusnook
POSTGRES_USER=focusnook
POSTGRES_PASSWORD=change-me-long-random-postgres-password

FOCUSNOOK_DATABASE_URL=postgres://focusnook:change-me-long-random-postgres-password@postgres:5432/focusnook
FOCUSNOOK_BIND_ADDR=0.0.0.0:8080
FOCUSNOOK_PUBLIC_BASE_URL=https://sync.example.com
FOCUSNOOK_DOMAIN=sync.example.com

# Generate with:
# openssl rand -base64 32
FOCUSNOOK_ADMIN_TOKEN=change-me-admin-bootstrap-token
FOCUSNOOK_WEB_SECONDARY_PASSWORD=change-me-web-secondary-password
FOCUSNOOK_TOKEN_PEPPER_B64=change-me-32-byte-base64-token-pepper
FOCUSNOOK_ENCRYPTION_KEY_B64=change-me-32-byte-base64-aes-key

FOCUSNOOK_MAX_OPS_PER_EXCHANGE=500
FOCUSNOOK_MAX_OPERATION_PAYLOAD_BYTES=262144
FOCUSNOOK_MAX_BLOB_BYTES=15728640
FOCUSNOOK_BACKUP_INTERVAL_SECONDS=86400
FOCUSNOOK_BACKUP_DIR=./backups
RUST_LOG=focusnook_sync_server=info,tower_http=info
