<?xml version="1.0" encoding="utf-8"?>
<!-- API 31+ defense in depth; android:allowBackup is also false. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="file" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="." />
    </device-transfer>
</data-extraction-rules>
